#!/usr/bin/env bash
set -euo pipefail

self_path="$(cd "$(dirname "$0")" && pwd -P)/$(basename "$0")"

for candidate in \
  "${HOMEBREW_PREFIX:-/opt/homebrew}/bin/sesh" \
  "/usr/local/bin/sesh" \
  "/home/linuxbrew/.linuxbrew/bin/sesh"
do
  if [[ -x "$candidate" && "$candidate" != "$self_path" ]]; then
    exec "$candidate" "$@"
  fi
done

while IFS= read -r candidate; do
  if [[ -n "$candidate" && -x "$candidate" && "$candidate" != "$self_path" ]]; then
    exec "$candidate" "$@"
  fi
done < <(which -a sesh 2>/dev/null || true)

printf 'sesh shim: no usable sesh binary found outside %s\n' "$self_path" >&2
printf 'Install sesh with Homebrew or your system package manager.\n' >&2
exit 127
